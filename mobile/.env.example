# DayPlan Mobile env vars
# Read by react-native-config — values are baked in at native build time.
# Rebuild the app (npx react-native run-ios / run-android) after changing.

API_URL=http://10.0.2.2:3000/api

# iOS simulator: http://localhost:3000/api
# Android emulator: http://10.0.2.2:3000/api  (emulator's alias for host's localhost)
# Real device: http://YOUR_LAN_IP:3000/api  (e.g. http://192.168.1.10:3000/api)
