# Database
DATABASE_URL="postgresql://dayplan:dayplan@localhost:5432/dayplan?schema=public"

# Auth
JWT_SECRET="change-this-to-a-long-random-string"
JWT_EXPIRES_IN="30d"

# Discord bot — get these from https://discord.com/developers/applications
# In the portal: OAuth2 → enable "Guild Install" (Installation), add the redirect below to Redirects.
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""
DISCORD_BOT_TOKEN=""
DISCORD_REDIRECT_URI="http://localhost:3000/auth/discord/callback"
# Optional: 0 = guild install (default), 1 = user install — must match what the app supports in the portal.
# DISCORD_OAUTH_INTEGRATION_TYPE=0

# Mobile app deep link (where to redirect after Discord OAuth)
MOBILE_DEEP_LINK_PREFIX="dayplan://"

# App
PORT=3000
NODE_ENV=development

# ── Scheduled Discord posting ────────────────────────────────────────────────
# The scheduler posts each user's "TODAY GOAL" / "Work Updated" at their
# configured times. There are two ways to drive it:
#
# 1. In-process cron (only fires while the Node process is alive and awake).
#    Enable on an always-on host (paid Render/Fly/VM/container). Leave OFF on a
#    sleeping free tier or serverless — the timer won't run there.
ENABLE_INPROCESS_CRON=true
#
# 2. External cron → secured HTTP endpoint (works everywhere, incl. free tiers).
#    Point an external scheduler (cron-job.org, GitHub Action, Upstash, …) at
#    POST /api/internal/cron/run-due-posts every minute, sending this secret in a
#    header: `Authorization: Bearer <CRON_SECRET>` or `X-Cron-Key: <CRON_SECRET>`.
#    (Header, not a ?key= query param — a query param would leak into access
#    logs/CDN/APM.) Leave empty to disable the endpoint (it fails closed). Use a
#    long random string in production.
CRON_SECRET=""
