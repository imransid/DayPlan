# Database
DATABASE_URL="postgresql://dayplan:dayplan@localhost:5432/dayplan?schema=public"

# Auth
JWT_SECRET="change-this-to-a-long-random-string"
JWT_EXPIRES_IN="30d"

# Discord bot — get these from https://discord.com/developers/applications
# In the portal: OAuth2 → enable "Guild Install" (Installation), add the redirect below to Redirects.
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""
DISCORD_BOT_TOKEN=""
DISCORD_REDIRECT_URI="http://localhost:3000/auth/discord/callback"
# Optional: 0 = guild install (default), 1 = user install — must match what the app supports in the portal.
# DISCORD_OAUTH_INTEGRATION_TYPE=0

# Mobile app deep link (where to redirect after Discord OAuth)
MOBILE_DEEP_LINK_PREFIX="dayplan://"

# App
PORT=3000
NODE_ENV=development

# ── Scheduled Discord posting ────────────────────────────────────────────────
# The scheduler posts each user's "TODAY GOAL" / "Work Updated" at their
# configured times. Posting is idempotent per (user, kind, local-day), so it is
# safe to drive it from several of these at once — they don't double-post. There
# are THREE ways to drive it; use as many as apply:
#
# 1. In-process cron — DEFAULT ON. Ticks every minute while the Node process is
#    alive and awake. Set to "false" only to disable (e.g. a purely serverless
#    runtime). NOTE: on a sleeping free tier (Render free) it can't tick while
#    the dyno is asleep — combine it with #2 and/or rely on #3.
ENABLE_INPROCESS_CRON=true
#
# 2. External cron → secured HTTP endpoint (works everywhere, incl. free tiers).
#    Point an external scheduler (cron-job.org, GitHub Action, Upstash, …) at
#    POST /api/internal/cron/run-due-posts every minute, sending this secret in a
#    header: `Authorization: Bearer <CRON_SECRET>` or `X-Cron-Key: <CRON_SECRET>`.
#    This repo ships .github/workflows/scheduled-posts.yml which does exactly
#    this every 5 min — but it only works once you set, in the repo's
#    Settings → Secrets and variables → Actions:
#        Variable  BACKEND_URL  = https://<your-backend>   (no trailing slash)
#        Secret    CRON_SECRET  = the SAME value as this env var
#    If those are unset the Action fails and nothing posts (the usual cause of
#    "manual works, auto doesn't"). Confirm it's running via GET
#    /api/internal/cron/status (same header auth) — lastRun should advance.
#    (Header, not a ?key= query param — a query param would leak into access
#    logs/CDN/APM.) Leave empty to disable the endpoint (it fails closed). Use a
#    long random string in production.
CRON_SECRET=""
#
# 3. Per-user foreground trigger — always on, no config. The mobile app calls
#    POST /api/scheduler/run-mine (JWT-auth) when it opens/foregrounds, so a
#    user's due post fires the moment they open the app after their set time.
#    This is the reliable fallback on a sleeping free tier.
#
# Note: a manual "Send now" records a success for the day, so the automatic post
# for that same kind is then skipped for the rest of that local day (no
# double-post). To test auto-posting, use a day/user where you haven't already
# hit "Send now".
