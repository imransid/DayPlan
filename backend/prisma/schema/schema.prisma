generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String  @id @default(uuid())
  email        String  @unique
  passwordHash String
  name         String?
  timezone     String  @default("UTC")

  // Time-of-day strings in 24h "HH:mm" format, evaluated against the user's timezone.
  // - goalPostTime    → posts the "TODAY GOAL" list (every task planned for today)
  // - workUpdateTime  → posts the "Work Updated" list (only completed tasks)
  // endOfDayTime is kept for backward compat but is no longer used by the scheduler.
  goalPostTime   String @default("09:00")
  workUpdateTime String @default("18:00")
  endOfDayTime   String @default("23:00")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tasks              Task[]
  discordConnections DiscordConnection[]
  reminderSchedule   ReminderSchedule?
  postLogs           PostLog[]

  // Team channels: feeds this user owns, and feeds they've joined as a member.
  ownedSharedChannels SharedChannel[]       @relation("SharedChannelOwner")
  sharedMemberships   SharedChannelMember[]

  @@map("users")
}

model Task {
  id       String    @id @default(uuid())
  userId   String
  title    String
  date     DateTime  @db.Date
  doneAt   DateTime?
  position Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@map("tasks")
}

model DiscordConnection {
  id             String    @id @default(uuid())
  userId         String
  guildId        String
  guildName      String
  accessToken    String
  refreshToken   String?
  tokenExpiresAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  channels DiscordChannel[]
  sharedChannels SharedChannel[]

  @@unique([userId, guildId])
  @@map("discord_connections")
}

model DiscordChannel {
  id           String        @id @default(uuid())
  connectionId String
  channelId    String
  channelName  String
  enabled      Boolean       @default(true)
  format       ChannelFormat @default(EMBED)

  // Per-channel routing for the new posts. A channel can receive both, one, or neither.
  // If both are false, the channel is effectively muted regardless of `enabled`.
  postGoals   Boolean @default(true)
  postUpdates Boolean @default(true)

  lastPostedAt DateTime?
  lastError    String?

  // Incoming webhook (our app) so posts can use a custom Discord username.
  webhookId    String?
  webhookToken String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  connection DiscordConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@unique([connectionId, channelId])
  @@map("discord_channels")
}

enum ChannelFormat {
  EMBED
  PLAIN
  COMPACT
}

model ReminderSchedule {
  id              String  @id @default(uuid())
  userId          String  @unique
  startTime       String  @default("09:00")
  endTime         String  @default("21:00")
  hourlyEnabled   Boolean @default(true)
  endOfDayEnabled Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("reminder_schedules")
}

model PostLog {
  id           String   @id @default(uuid())
  userId       String
  date         DateTime @db.Date
  postedAt     DateTime @default(now())
  channelId    String?
  channelName  String?
  // 'goal' | 'work_update' | 'wrap' (legacy)
  kind         String   @default("wrap")
  status       String
  errorCode    Int?
  errorMessage String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@map("post_logs")
}

// ─── Team / shared channels ────────────────────────────────────────────────
// A DiscordChannel (in an admin's guild, bot present) flagged as a shared
// "team feed". Members join via `joinCode` and their scheduled goal/work-update
// posts are delivered here (attributed by webhook username). Members do NOT
// need their own Discord connection — the owner's bot posts on their behalf.
model SharedChannel {
  id           String @id @default(uuid())
  ownerUserId  String // the admin who owns the feed
  connectionId String // which DiscordConnection this channel belongs to
  channelId    String // Discord text channel id (bot present)
  channelName  String

  joinCode    String  @unique // high-entropy Base62; rotatable
  enabled     Boolean @default(true) // master off-switch for the whole feed
  postGoals   Boolean @default(true) // route "TODAY GOAL" posts here
  postUpdates Boolean @default(true) // route "Work Updated" posts here
  maxMembers  Int     @default(50) // membership cap

  // Same webhook plumbing as DiscordChannel so the poster can treat it identically.
  webhookId    String?
  webhookToken String?
  lastError    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner      User                  @relation("SharedChannelOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  connection DiscordConnection     @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  members    SharedChannelMember[]

  // One shareable feed per (connection, channel); re-flagging is an idempotent upsert.
  @@unique([connectionId, channelId])
  @@index([ownerUserId])
  @@map("shared_channels")
}

model SharedChannelMember {
  id              String  @id @default(uuid())
  sharedChannelId String
  userId          String
  enabled         Boolean @default(true) // member can pause their own posting without leaving

  createdAt DateTime @default(now())

  sharedChannel SharedChannel @relation(fields: [sharedChannelId], references: [id], onDelete: Cascade)
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sharedChannelId, userId]) // duplicate-join guard
  @@index([userId])
  @@map("shared_channel_members")
}

// Per-(member, shared channel, kind, local-day) idempotency — kept separate from
// PostLog so a member's shared post is independent of their personal posts.
model SharedChannelPostLog {
  id              String   @id @default(uuid())
  sharedChannelId String
  userId          String
  date            DateTime @db.Date
  postedAt        DateTime @default(now())
  kind            String // 'goal' | 'work_update'
  status          String // 'success' | 'failed'
  errorCode       Int?
  errorMessage    String?

  @@index([sharedChannelId, userId, date, kind])
  @@map("shared_channel_post_logs")
}
