{
  "name": "dayplan-backend",
  "version": "1.0.0",
  "description": "DayPlan NestJS backend with CQRS, Prisma, PostgreSQL",
  "scripts": {
    "build": "prisma generate && nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main",
    "clean": "rm -rf dist",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "CI=true jest --runInBand",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "fix-watchman": "watchman watch-del \"$(pwd)\" 2>/dev/null; watchman watch-project \"$(pwd)\"",
    "test:chat-reactions": "node test/scripts/test-chat-reactions.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:push:reset": "prisma db push --force-reset",
    "db:pull": "prisma db pull",
    "db:studio": "prisma studio",
    "db:migrate": "prisma migrate dev",
    "db:migration": "prisma migrate dev --name",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:status": "prisma migrate status",
    "db:migrate:reset": "prisma migrate reset",
    "db:migatre": "npm run db:migrate",
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/cli": "10.4.5",
    "@nestjs/common": "10.4.15",
    "@nestjs/config": "3.3.0",
    "@nestjs/core": "10.4.15",
    "@nestjs/cqrs": "10.2.7",
    "@nestjs/jwt": "10.2.0",
    "@nestjs/passport": "10.0.3",
    "@nestjs/platform-express": "10.4.15",
    "@nestjs/schedule": "4.1.2",
    "@nestjs/swagger": "7.4.2",
    "@prisma/adapter-pg": "^7.2.0",
    "@prisma/client": "^7.2.0",
    "axios": "1.7.9",
    "bcryptjs": "^3.0.3",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.1",
    "dotenv": "^17.4.2",
    "luxon": "3.5.0",
    "passport": "0.7.0",
    "passport-jwt": "4.0.1",
    "pg": "^8.20.0",
    "prisma": "^7.2.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.1"
  },
  "devDependencies": {
    "@nestjs/schematics": "10.2.3",
    "@types/bcryptjs": "^3.0.0",
    "@types/express": "^5.0.6",
    "@types/luxon": "3.4.2",
    "@types/node": "20.17.6",
    "@types/passport-jwt": "^4.0.1",
    "ts-node": "10.9.2",
    "tsx": "^4.22.4",
    "typescript": "5.7.2"
  },
  "packageManager": "yarn@4.13.0+sha512.5c20ba010c99815433e5c8453112165e673f1c7948d8d2b267f4b5e52097538658388ebc9f9580656d9b75c5cc996f990f611f99304a2197d4c56d21eea370e7"
}
